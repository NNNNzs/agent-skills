# 若依系统 API 配置示例
# 将此文件重命名为 .ruoyi-config.json 并填入实际值

{
  "baseUrl": "http://localhost:3700",
  "token": "your_bearer_token_here"
}

# Token 获取方式：
# 1. 登录若依系统
# 2. 打开浏览器开发者工具（F12）-> Network 标签
# 3. 刷新页面，找到任意请求
# 4. 查看请求头中的 Authorization 字段
# 5. 复制 Bearer 后面的 token 值
#
# 或者通过登录接口获取：
# curl -X POST http://localhost:3700/auth/login \
#   -H "Content-Type: application/json" \
#   -d '{"username":"admin","password":"admin123"}'
